{
  "$schema": "../../../schemas/project_config.schema.json",
  "project": {
    "id": "minimal-project",
    "name": "Minimal Project",
    "role": "example-adopter",
    "description": "Synthetic example showing a small Project Ops adopter config."
  },
  "paths": {
    "roadmap": "docs/roadmap/roadmap.md",
    "inProgress": "docs/roadmap/in_progress",
    "completed": "docs/roadmap/completed",
    "reports": "docs/reports",
    "changelog": "docs/reports/changelog.md",
    "governance": "docs/governance",
    "requestTemplate": "docs/roadmap/in_progress/_REQUEST_TEMPLATE.md",
    "projectOpsContract": "docs/project_ops.md",
    "templateRoot": "docs/templates",
    "projectAdminBaselineTemplate": "docs/templates/project_admin_baseline.md"
  },
  "scopeLabels": [
    "governance",
    "docs",
    "runtime",
    "tests"
  ],
  "requiredDocs": [
    "README.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    ".gitignore",
    ".project_ops/config.json",
    "docs/project_ops.md",
    "docs/roadmap/roadmap.md",
    "docs/roadmap/in_progress/_REQUEST_TEMPLATE.md",
    "docs/architecture/README.md",
    "docs/governance/README.md",
    "docs/reports/changelog.md"
  ],
  "privacy": {
    "defaultVisibility": "public",
    "publicExamplesRequireSanitization": true,
    "privateHistoryPaths": [
      "docs/private/**",
      ".local/**"
    ]
  },
  "validation": {
    "requireChangelog": true,
    "requireRoadmapParity": true,
    "allowEmptyRoadmap": true,
    "dryRunByDefault": true,
    "commands": [
      {
        "name": "project-ops-audit",
        "command": "python ../../tools/project_ops_audit.py --repo examples/minimal_project",
        "required": true,
        "description": "Audit the synthetic minimal adopter without rewriting files."
      }
    ]
  },
  "bootstrap": {
    "requiredFiles": [
      "README.md",
      "docs/project_ops.md",
      "docs/roadmap/roadmap.md",
      "docs/roadmap/in_progress/_REQUEST_TEMPLATE.md",
      "docs/reports/changelog.md"
    ],
    "recommendedFiles": [
      "docs/architecture/README.md",
      "docs/governance/README.md"
    ],
    "initialDirectories": [
      "docs/architecture",
      "docs/governance",
      "docs/roadmap/in_progress",
      "docs/roadmap/completed",
      "docs/reports"
    ]
  },
  "adoption": {
    "mode": "manual-templates",
    "frameworkRepo": "https://github.com/tensegrity-audio/project_ops",
    "frameworkRepoName": "project_ops",
    "frameworkProductName": "Project Ops"
  }
}
