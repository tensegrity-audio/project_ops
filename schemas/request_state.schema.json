{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tensegrity-audio.github.io/project_ops/schemas/v0.1.2/request_state.schema.json",
  "title": "Project Ops Request State",
  "description": "Portable state sidecar for a Project Ops managed request artifact.",
  "type": "object",
  "required": [
    "requestId",
    "requestPath",
    "phase",
    "state",
    "status",
    "updatedAt",
    "history"
  ],
  "properties": {
    "requestId": { "type": "string", "minLength": 1 },
    "requestPath": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": [
        "INTAKE",
        "FORM",
        "ANALYSIS",
        "PLAN",
        "EXECUTION",
        "VALIDATION",
        "DOC_SYNC",
        "POST_MORTEM",
        "COMPLETE"
      ]
    },
    "state": {
      "type": "string",
      "enum": ["DRAFT", "LOCKED", "ACTIVE"]
    },
    "status": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "phase", "state", "event"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "phase": {
            "type": "string",
            "enum": [
              "INTAKE",
              "FORM",
              "ANALYSIS",
              "PLAN",
              "EXECUTION",
              "VALIDATION",
              "DOC_SYNC",
              "POST_MORTEM",
              "COMPLETE"
            ]
          },
          "state": { "type": "string", "enum": ["DRAFT", "LOCKED", "ACTIVE"] },
          "event": { "type": "string" },
          "note": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
